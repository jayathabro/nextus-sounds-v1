# =============================================================================
# NEXTUS SOUNDS — Environment Configuration
# =============================================================================
# ⚠️  NEVER commit this file to git!  ⚠️
# 1. Copy this file to `.env`:    cp .env.example .env
# 2. Replace placeholder values with your real values
# 3. Keep `.env` private — never paste your token in Discord/chat
# =============================================================================

# -----------------------------------------------------------------------------
# Discord Bot Token (REQUIRED)
# -----------------------------------------------------------------------------
# Get from: https://discord.com/developers/applications → Bot → Reset Token
# ⚠️  IF THIS LEAKS, RESET IT IMMEDIATELY!
DISCORD_TOKEN=YOUR_BOT_TOKEN_HERE

# -----------------------------------------------------------------------------
# Bot Owner (REQUIRED for owner-only commands)
# -----------------------------------------------------------------------------
# Your Discord User ID. Get it: Discord Settings → My Account → Copy User ID
# (Enable Developer Mode in Discord Settings → Advanced first)
OWNER_ID=YOUR_DISCORD_USER_ID_HERE

# -----------------------------------------------------------------------------
# Lavalink (REQUIRED for music playback)
# -----------------------------------------------------------------------------
# Public default below works for most users. Self-host for production.
LAVALINK_HOST=lavalink.jockie.dev
LAVALINK_PORT=443
LAVALINK_PASSWORD=password
LAVALINK_SECURE=true

# -----------------------------------------------------------------------------
# Welcome Sound (Optional)
# -----------------------------------------------------------------------------
ENABLE_WELCOME_SOUND=true
WELCOME_SOUND_FILE=welcome.mp3

# -----------------------------------------------------------------------------
# Language (Optional)
# -----------------------------------------------------------------------------
# si = Sinhala (default), en = English
DEFAULT_LANGUAGE=si

# -----------------------------------------------------------------------------
# Optional APIs (for lyrics & advanced Spotify metadata)
# -----------------------------------------------------------------------------
# Genius API key — get from: https://genius.com/api-clients
GENIUS_API_KEY=

# Spotify API — get from: https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Bot Configuration (Optional)
# -----------------------------------------------------------------------------
# Activity status cycle interval (minutes)
STATUS_CYCLE_MINUTES=5
# Max queue size
MAX_QUEUE=100
# Auto-leave timeout (seconds)
AUTO_LEAVE_TIMEOUT=180